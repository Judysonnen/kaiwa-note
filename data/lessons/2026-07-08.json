  "grammar": [
    {
      "id": "g01",
      "pattern": "Verb + たいです",
      "explanation": "want to do something",
      "examples": [
        {
          "ja": "食べたいです",
          "zh": "想吃。"
        },
        {
          "ja": "ピアノも習いたいです",
          "zh": "也想学钢琴。"
        }
      ],
      "detail": "接续：动词ます形去掉ます＋たい。表示第一人称「想做某事」（疑问句可用于第二人称）。たい本身按い形容词变化：食べたくないです（不想吃）、食べたかったです（当时想吃）。"
    },
    {
      "id": "g02",
      "pattern": "〜ています",
      "explanation": "て-form + います: ongoing action or habit",
      "examples": [
        {
          "ja": "4歳から弾いています",
          "zh": "从四岁一直弹到现在。"
        },
        {
          "ja": "ブログを書いています",
          "zh": "在写博客。"
        }
      ],
      "detail": "接续：动词て形＋います。两个核心用法：①动作正在进行（ブログを書いています＝在写博客/有写博客的习惯）；②从过去持续到现在的状态或习惯（4歳から弾いています＝从4岁一直弹到现在）。"
    },
    {
      "id": "g03",
      "pattern": "（理由）〜から、〜",
      "explanation": "gives a reason: because (reason), (statement)",
      "examples": [
        {
          "ja": "私は大学院に行きましたから、その学生より年齢が上です",
          "zh": "因为我读了研究生，所以比那个学生年长。"
        },
        {
          "ja": "働いていますから、時間があまりありません",
          "zh": "因为在工作，没什么时间。"
        }
      ],
      "detail": "接续：句子（可以是です/ます礼貌形）＋から，先说理由再说结论。から直接接在礼貌形后面是它和ので的一个区别，口语中主观、直接。"
    },
    {
      "id": "g04",
      "pattern": "〜ので",
      "explanation": "gives a reason, softer than から",
      "examples": [
        {
          "ja": "働いていて時間があまりないので、最近はブログを書いていません",
          "zh": "因为工作忙没什么时间，最近没在写博客。"
        }
      ],
      "detail": "接续：普通形＋ので（な形容词和名词用〜なので）。同样表原因，但比から更客观柔和，用来委婉地解释情况，不显得在强调自己的主张。拒绝或道歉时用ので更礼貌。"
    },
    {
      "id": "g05",
      "pattern": "います / あります",
      "explanation": "います for people and animals, あります for things",
      "examples": [
        {
          "ja": "人がたくさんいました",
          "zh": "当时有很多人。"
        }
      ],
      "detail": "存在动词的分工：有生命的（人、动物）用います，无生命的（东西、植物、事件）用あります。人がたくさんいました＝当时有很多人。"
    },
    {
      "id": "g06",
      "pattern": "〜か + わかりません",
      "explanation": "embedded question: I don't know (what / whether) ...",
      "examples": [
        {
          "ja": "どんな仕事が好きかわかりません",
          "zh": "不知道自己喜欢什么样的工作。"
        }
      ],
      "detail": "嵌入疑问句：疑问词的问句变普通形＋か，塞进大句子里。どんな仕事が好きか＋わかりません＝不知道自己喜欢什么样的工作。嵌入部分不用です/ます。"
    },
    {
      "id": "g07",
      "pattern": "〜かどうか",
      "explanation": "whether or not",
      "examples": [
        {
          "ja": "ベストセラーかどうかわかりません",
          "zh": "不知道是不是畅销书。"
        }
      ],
      "detail": "没有疑问词的「是否」用かどうか：普通形＋かどうか。ベストセラーかどうかわかりません＝不知道是不是畅销书。名词直接＋かどうか，不加だ。"
    },
    {
      "id": "g08",
      "pattern": "〜だけじゃなくて…も",
      "explanation": "not only ... but also ...",
      "examples": [
        {
          "ja": "ミステリーだけじゃなくてノンフィクションも読みます",
          "zh": "不只推理小说，也读非虚构。"
        }
      ],
      "detail": "AだけじゃなくてBも＝不仅A而且B。じゃなくて是ではなくて的口语缩略。注意后半句用も呼应。"
    },
    {
      "id": "g09",
      "pattern": "〜によってちがいます",
      "explanation": "it depends on ...",
      "examples": [
        {
          "ja": "何を弾きたいかによってちがいます",
          "zh": "取决于你想弹什么。"
        }
      ],
      "detail": "名词＋によって（ちがいます）＝因…而异。前面还可以接嵌入疑问句：何を弾きたいかによって＝取决于你想弹什么。"
    },
    {
      "id": "g10",
      "pattern": "Potential form（読める）",
      "explanation": "can do: 読む → 読めます",
      "examples": [
        {
          "ja": "中国語の本は速く読めます",
          "zh": "中文书能读得很快。"
        }
      ],
      "detail": "可能形变位：一类动词词尾う段→え段＋ます（読む→読めます）；二类动词去る＋られます（食べられます）；する→できます、来る→来られます。可能形句中宾语的を常改成が：本が読めます。"
    },
    {
      "id": "g11",
      "pattern": "おいくつですか？",
      "explanation": "polite way to ask age: いくつですか / おいくつですか = 何歳ですか",
      "examples": [
        {
          "ja": "おいくつですか？",
          "zh": "您多大年纪？"
        }
      ],
      "detail": "问年龄的礼貌层级：何歳ですか（直接）→ いくつですか → おいくつですか（最礼貌，加了美化语お）。对长辈或初次见面用おいくつですか。"
    },
    {
      "id": "g12",
      "pattern": "特にないです",
      "explanation": "nothing in particular; ≠ 別に, which can sound curt",
      "examples": [
        {
          "ja": "特にいないです。いろいろな作家の本を読みます。",
          "zh": "没有特别喜欢的，各种作家的书都读。"
        }
      ],
      "detail": "被问「有没有…」时，「没有特别的」用特にないです（人用特にいないです），自然又礼貌。别に（ないです）字面意思相近，但语气冷淡敷衍，容易失礼，会话中避免。"
    },
    {
      "id": "g13",
      "pattern": "AはBより〜",
      "explanation": "comparison: A is more ... than B; 年齢が上です = older",
      "examples": [
        {
          "ja": "私は大学院に行きましたから、その学生より年齢が上です",
          "zh": "因为我读了研究生，所以比那个学生年长。"
        }
      ],
      "detail": "比较句：BよりA（のほうが）〜＝A比B更…。例句里年齢が上です＝年纪更大（上/下用于年龄高低）。より前面是被比下去的那一方。"
    },
    {
      "id": "g14",
      "pattern": "Plain past + noun（読んだ本）",
      "explanation": "plain past verb modifies a noun: the book (I) read",
      "examples": [
        {
          "ja": "最近読んだ本は、Never Let Me Goです",
          "zh": "最近读的书是《别让我走》。"
        }
      ],
      "detail": "日语没有关系代词，动词普通形直接放在名词前面修饰它：読んだ本＝读过的书、最近読んだ本＝最近读的书。整个从句里不用です/ます。"
    }
  ],
  "sentences": [
    {
      "id": "s01",
      "ja": "アメリカ人はあまり行きません",
      "meaning": "Americans don't go there much.",
      "zh": "美国人不太去（吃火锅）。",
      "breakdown": [
        "あまり＋否定＝「不太…」，あまり只能配否定句",
        "行きません＝行く的ます形否定"
      ]
    },
    {
      "id": "s02",
